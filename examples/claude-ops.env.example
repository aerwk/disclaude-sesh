# claude-ops configuration — copy to ~/.config/claude-ops.env and chmod 600.
# Read by the claude-supervisor systemd unit AND by bin/claude-ops.sh.

# Bot token for the SUPERVISOR bot (Discord Developer Portal → your
# supervisor application → Bot → Reset Token). NOT the channel bot's token —
# that one is saved separately by /discord:configure inside Claude Code.
SUPERVISOR_BOT_TOKEN=paste-supervisor-bot-token-here

# Your Discord user ID (comma-separate several). Right-click your name in
# Discord with Developer Mode enabled → Copy User ID. Only these users can
# drive the supervisor; everyone else is silently ignored.
ALLOWED_USER_IDS=000000000000000000

# ── Optional ────────────────────────────────────────────────────────────────

# Working directory for the Claude Code ops session.
# Default: <repo>/workspace
#CLAUDE_OPS_WORKSPACE=

# 1 = run the session with --dangerously-skip-permissions: tools execute
# WITHOUT Allow/Deny prompts. Read "Permission modes" in the README before
# turning this on. Default: 0 (prompts arrive as buttons in Discord).
#CLAUDE_OPS_SKIP_PERMISSIONS=0

# 1 = apply (and keep re-applying) the channel-buttons patch so permission
# prompts post to your ops channel instead of DMs.
# See docs/channel-buttons-patch.md. Default: 0 (stock DM behaviour).
#CLAUDE_OPS_CHANNEL_BUTTONS=1

# Channel ID the repatcher posts its 🔧/⚠️ notices to (usually your ops
# channel). Required only when CLAUDE_OPS_CHANNEL_BUTTONS=1.
#OPS_CHANNEL_ID=000000000000000000
